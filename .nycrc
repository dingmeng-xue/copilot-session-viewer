{
  "all": true,
  "include": [
    "server.js",
    "src/**/*.js",
    "public/**/*.js"
  ],
  "exclude": [
    "**/*.test.js",
    "**/__tests__/**",
    "**/node_modules/**",
    "coverage/**",
    ".nyc_output/**",
    "test-results/**",
    "scripts/**",
    "**/*.spec.js"
  ],
  "reporter": [
    "text",
    "text-summary",
    "html",
    "lcov"
  ],
  "report-dir": "./coverage/combined",
  "temp-dir": "./.nyc_output",
  "cache": true,
  "sourceMap": false,
  "instrument": false
}
