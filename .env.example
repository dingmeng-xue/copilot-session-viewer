# Copilot Session Viewer - Environment Configuration

# Server port
PORT=3838

# Node environment (development | production)
NODE_ENV=development

# Session state directory path
# Default: ~/.copilot/session-state
SESSION_DIR=/Users/yourusername/.copilot/session-state

# Optional: Enable debug logging
# DEBUG=copilot-session-viewer:*

# Application Insights Telemetry Configuration
# Connection string for Azure Application Insights
# Leave commented out to use default connection string
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# Disable telemetry (set to 'true' to disable)
# Telemetry is automatically disabled in test environments (NODE_ENV=test)
# DISABLE_TELEMETRY=false
